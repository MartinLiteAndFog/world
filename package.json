{
  "name": "street-stocks",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo run build",
    "build:api": "pnpm --filter @street-stocks/api build",
    "build:jobs": "pnpm --filter @street-stocks/jobs build",
    "build:web": "pnpm --filter @street-stocks/web build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start:api": "pnpm --filter @street-stocks/api start",
    "start:web": "pnpm --filter @street-stocks/web start",
    "dev:api": "pnpm --filter @street-stocks/api dev",
    "dev:web": "pnpm --filter @street-stocks/web dev",
    "dev:up": "./scripts/dev-up.sh",
    "db:migrate": "node --import tsx -e \"import { applySqlMigrations } from './packages/db/src/index.ts'; await applySqlMigrations();\"",
    "reset-db": "./scripts/reset-db.sh",
    "jobs:seed": "pnpm --filter @street-stocks/jobs jobs:seed && pnpm --filter @street-stocks/jobs jobs:normalize",
    "jobs:normalize": "pnpm --filter @street-stocks/jobs jobs:normalize",
    "jobs:score": "pnpm --filter @street-stocks/jobs jobs:score",
    "jobs:bootstrap": "pnpm db:migrate && pnpm jobs:seed && pnpm jobs:score"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2"
  }
}
