{
  "name": "@street-stocks/jobs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "jobs:seed": "node --import tsx ./src/index.ts seed",
    "jobs:normalize": "node --import tsx ./src/index.ts normalize",
    "jobs:score": "node --import tsx ./src/index.ts score",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@street-stocks/db": "workspace:*",
    "@street-stocks/ingestion": "workspace:*",
    "@street-stocks/scoring": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
